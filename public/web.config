<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- ── MIME Types ──────────────────────────────────────────────────────── -->
    <!-- Remove first to avoid "duplicate entry" errors on re-deploy          -->
    <staticContent>
      <remove fileExtension=".wasm" />
      <mimeMap fileExtension=".wasm"  mimeType="application/wasm" />

      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json"  mimeType="application/json" />

      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff"  mimeType="font/woff" />

      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />

      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg"   mimeType="image/svg+xml" />

      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp"  mimeType="image/webp" />
    </staticContent>

    <!-- ── SPA Fallback (React Router) ────────────────────────────────────── -->
    <!-- Requires IIS URL Rewrite Module (free from Microsoft).               -->
    <!-- Any URL that is NOT a real file or folder → serve index.html         -->
    <rewrite>
      <rules>
        <rule name="SPA React Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory"  negate="true" />
          </conditions>
          <action type="Rewrite" url="/eodb_test/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- ── Cache-Control Headers ───────────────────────────────────────────── -->
    <!-- Vite hashes JS/CSS/font filenames — safe to cache 1 year.            -->
    <!-- index.html must never be cached (always fetch fresh).                -->
    <caching>
      <profiles>
        <add extension=".js"    policy="CacheForTimePeriod" duration="365.00:00:00" varyByHeaders="Accept-Encoding" />
        <add extension=".css"   policy="CacheForTimePeriod" duration="365.00:00:00" varyByHeaders="Accept-Encoding" />
        <add extension=".wasm"  policy="CacheForTimePeriod" duration="365.00:00:00" />
        <add extension=".woff"  policy="CacheForTimePeriod" duration="365.00:00:00" />
        <add extension=".woff2" policy="CacheForTimePeriod" duration="365.00:00:00" />
        <add extension=".png"   policy="CacheForTimePeriod" duration="30.00:00:00"  />
        <add extension=".jpg"   policy="CacheForTimePeriod" duration="30.00:00:00"  />
        <add extension=".svg"   policy="CacheForTimePeriod" duration="30.00:00:00"  />
      </profiles>
    </caching>

    <!-- ── Security Headers ────────────────────────────────────────────────── -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options"        value="SAMEORIGIN" />
        <add name="Referrer-Policy"        value="strict-origin-when-cross-origin" />
        <!-- HSTS: enforce HTTPS for 1 year including subdomains.
             Only activate this once the entire domain (incl. subdomains) is HTTPS.
             TODO (IIS admin): Move to the HTTPS binding in IIS Manager if HTTP binding also exists. -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
        <!-- CSP: tuned for self-hosted ArcGIS JS API 4.x (blob workers, inline styles/eval).
             connect-src lists every external service the app fetches at runtime.
             TODO (IIS admin): Review and tighten after confirming all basemap tile origins.
             unsafe-eval is required by ArcGIS SDK workers; do not remove.
             unsafe-inline (style-src) is required by ArcGIS SDK; do not remove. -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.arcgisonline.com https://*.arcgis.com https://hsac.org.in https://hsacggm.in https://onemapggm.gmda.gov.in; font-src 'self' data:; connect-src 'self' https://hsac.org.in https://hsacggm.in https://onemapggm.gmda.gov.in https://geocode-api.arcgis.com https://services1.arcgis.com https://services.arcgisonline.com https://basemaps-api.arcgis.com https://*.arcgis.com; worker-src blob: 'self'; child-src blob:; frame-src 'none'; object-src 'none'; base-uri 'self'; frame-ancestors 'self';" />
        <!-- index.html: no-cache so browser always fetches the latest build -->
        <remove name="Cache-Control" />
      </customHeaders>
    </httpProtocol>

    <!-- ── Compression ─────────────────────────────────────────────────────── -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- ── Directory Listing: OFF ──────────────────────────────────────────── -->
    <directoryBrowse enabled="false" />

    <!-- ── Custom Error Pages ──────────────────────────────────────────────── -->
    <httpErrors errorMode="Custom" existingResponse="PassThrough">
      <remove statusCode="404" />
      <error statusCode="404" path="/eodb_test/index.html" responseMode="ExecuteURL" />
    </httpErrors>

  </system.webServer>
</configuration>
