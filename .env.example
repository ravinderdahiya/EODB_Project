# =============================================================================
# EODB Project — Environment Variable Reference

# =============================================================================

# ── HSAC MapServer ────────────────────────────────────────────────────────────
# Production base origin for the HSAC spatial server.
#VITE_HSAC_ORIGIN=https://harsac.online,https://www.harsac.online,https://hsac.org.in,https://www.hsac.org.in
#VITE_HSAC_ORIGIN=https://harsac.online/
VITE_HSAC_ORIGIN=https://www.hsac.org.in

# Vite dev-server proxy prefix that rewrites to VITE_HSAC_ORIGIN.
# Must start with "/". Keep in sync with the proxy key in vite.config.js.
VITE_HSAC_DEV_PROXY=/hsac


# You can find this in: Admin > Data Streams > Web > Measurement ID
VITE_GA_MEASUREMENT_ID=GA_MEASUREMENT_IDVITE_HSAC_DOTNET_PROXY_URL=https://hsac.org.in/DotNet/proxy.ashx

# ── HSAC ASMX Land-Record API ─────────────────────────────────────────────────
# Relative path — proxied to VITE_HSAC_ORIGIN in Vite dev; configure Nginx in prod.
VITE_ASMX_BASE_PATH=/LandOwnerAPI/getownername.asmx

# ── ArcGIS ───────────────────────────────────────────────────────────────────

# to the production domain in the ArcGIS developer dashboard.
VITE_ARCGIS_API_KEY=your_arcgis_api_key_here


VITE_SERVER_BASE_URL=http://localhost:8080
# VITE_SERVER_BASE_URL=https://hsac.org.in/eodb_backend
# ── Dev Server ────────────────────────────────────────────────────────────────
VITE_DEV_PORT=5173
VITE_BASENAME=/eodb_test
#VITE_BASENAME=/eodb

#VITE_GA_ID=G-XXXXXXXXXX
# WhatsApp number for feedback redirection (country code + number, no + sign).
VITE_FEEDBACK_WHATSAPP_NUMBER=919953532730
#VITE_FEEDBACK_WHATSAPP_NUMBER=919467273974
# Keep true to open WhatsApp chat window after submit.
VITE_FEEDBACK_OPEN_WHATSAPP_CHAT=true
