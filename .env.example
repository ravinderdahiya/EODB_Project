# =============================================================================
# EODB Project — Environment Variable Reference
# Copy this file to .env and fill in the real values.
# .env is git-ignored; this file is committed and documents every variable.
# =============================================================================

# ── HSAC MapServer ────────────────────────────────────────────────────────────
# Production base origin for the HSAC spatial server.
VITE_HSAC_ORIGIN=https://hsac.org.in

# Vite dev-server proxy prefix that rewrites to VITE_HSAC_ORIGIN.
# Must start with "/". Keep in sync with the proxy key in vite.config.js.
VITE_HSAC_DEV_PROXY=/hsac

# Path appended to the origin to form the full MapServer URL.
# Switch between EODB_Staging, EODB_HR21, etc.
VITE_HSAC_MAP_SERVICE_PATH=/server/rest/services/EODB/EODB_Staging/MapServer

# HSAC DotNet proxy — ArcGIS SDK routes authenticated MapServer requests through this.
# Usually the HSAC internal server-side proxy; leave as-is for standard deployments.
VITE_HSAC_DOTNET_PROXY_URL=http://hsac.org.in/DotNet/proxy.ashx

# ── HSAC ASMX Land-Record API ─────────────────────────────────────────────────
# Relative path — proxied to VITE_HSAC_ORIGIN in Vite dev; configure Nginx in prod.
VITE_ASMX_BASE_PATH=/LandOwnerAPI/getownername.asmx

# ── ArcGIS ───────────────────────────────────────────────────────────────────
# Optional. Leave blank to use public / unauthenticated access.
# Required for premium basemaps and high-volume geocoding.
VITE_ARCGIS_API_KEY=your_arcgis_api_key_here

# ArcGIS World Geocoder REST endpoint.
VITE_ARCGIS_GEOCODER_URL=https://geocode-api.arcgis.com/arcgis/rest/services/World/GeocodeServer

# ── External Feature Services ─────────────────────────────────────────────────
# Haryana state boundary polygon (ArcGIS Online public feature service).
VITE_HARYANA_BOUNDARY_URL=https://services1.arcgis.com/qN3V93cYGMKQCOxL/arcgis/rest/services/HARYANA_BOUNDARY/FeatureServer/0

# HSACGGM Government Assets MapServer.
VITE_HSACGGM_ASSETS_URL=https://hsacggm.in/server/rest/services/Onemap_Haryana/Government_Assets/MapServer

# NHAI National Highway Authority MapServer.
VITE_NHAI_ROADS_URL=https://onemapggm.gmda.gov.in/server/rest/services/NHAI_All/MapServer

# Haryana state road network MapServer.
VITE_HARYANA_ROADS_URL=https://hsacggm.in/server/rest/services/Onemap_Haryana/Haryana_Roads/MapServer

# ── Backend / Axios ───────────────────────────────────────────────────────────
# Base URL for the internal REST API consumed by axiosInstance.
# In production point this at your deployed API gateway.
VITE_SERVER_BASE_URL=http://localhost:8080

# ── Dev Server ────────────────────────────────────────────────────────────────
VITE_DEV_PORT=5173
