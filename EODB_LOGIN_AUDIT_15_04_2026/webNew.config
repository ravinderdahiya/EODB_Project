<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <system.web>
    <!-- Secure Cookies for ASP.NET pipeline -->
    <httpCookies httpOnlyCookies="true" requireSSL="true" sameSite="Strict" />

    <!-- Session Security -->
    <sessionState 
        mode="InProc" 
        timeout="30" 
        cookieSameSite="Strict" />

    <!-- Remove ASP.NET version leak -->
    <httpRuntime enableVersionHeader="false" />

    <!-- Do not show detailed errors to remote users -->
    <customErrors mode="RemoteOnly" />
  </system.web>

  <system.webServer>

    <!-- Node / iisnode handler -->
    <handlers>
      <add name="iisnode" path="app.js" verb="*" modules="iisnode" />
    </handlers>

    <iisnode enableXFF="true" debuggingEnabled="false" />

    <!-- Disable static content client cache -->
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>

    <!-- Request Filtering -->
    <security>
      <requestFiltering>
        <verbs allowUnlisted="true">
          <!-- Explicitly deny dangerous verbs -->
          <add verb="TRACE" allowed="false" />
          <add verb="TRACK" allowed="false" />
          <add verb="PUT" allowed="false" />
          <add verb="DELETE" allowed="false" />
          <add verb="CONNECT" allowed="false" />
          <add verb="OPTIONS" allowed="false" />
          <add verb="HEAD" allowed="false" />

          <!-- Allow safe methods -->
          <add verb="GET" allowed="true" />
          <add verb="POST" allowed="true" />
        </verbs>

        <!-- Hide Sensitive Paths -->
        <hiddenSegments>
          <add segment="node" />
          <add segment="configuration" />
          <add segment="iisnode" />
          <add segment="package.json" />
          <add segment="Public" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <rewrite>

      <!-- Optional map if you want to use it later -->
      <rewriteMaps>
        <rewriteMap name="AllowedOrigins">
          <add key="https://hsac.org.in" value="https://hsac.org.in" />
        </rewriteMap>
      </rewriteMaps>

      <rules>

        <!-- 1) Block invalid Host headers (Host Header Injection protection) -->
        <!-- <rule name="Block Invalid Host" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            
            <add input="{HTTP_HOST}" pattern="^hsac\.org\.in$" negate="true" />
          </conditions>
          <action type="CustomResponse" statusCode="400" statusReason="Bad Request" statusDescription="Invalid Host header" />
        </rule> -->

        <!-- 2) Force HTTPS for valid host -->
        <rule name="Force HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^hsac\.org\.in$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 3) Route all dynamic content to app.js (iisnode) -->
        <rule name="DynamicContent" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="app.js" />
        </rule>

      </rules>

      <!-- Outbound rules -->
      <outboundRules>

        <!-- Add security flags to all cookies -->
        <rule name="Add Cookie Security Flags">
          <match serverVariable="RESPONSE_Set-Cookie" pattern=".*" />
          <action type="Rewrite" value="{R:0}; Domain=hsac.org.in; Path=/; HttpOnly=True; Secure=True; SameSite=Strict" />
        </rule>

        <!-- Ensure HSTS header is present on HTTPS responses -->
        <rule name="Add HSTS Header">
          <match serverVariable="RESPONSE_Strict-Transport-Security" pattern=".*" />
          <conditions>
            <add input="{HTTPS}" pattern="on" ignoreCase="true" />
          </conditions>
          <action type="Rewrite" value="max-age=31536000; includeSubDomains; preload" />
        </rule>

        <!-- Remove IIS server banner -->
        <rule name="Remove Server Header">
          <match serverVariable="RESPONSE_Server" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>

      </outboundRules>

    </rewrite>

    <!-- Default document -->
    <!-- <defaultDocument>
      <files>
        <add value="maintain.html" />
      </files>
    </defaultDocument> -->

    <!-- HTTP protocol headers -->
    <httpProtocol>
      <customHeaders>

        <!-- Remove Identifying Headers -->
        <remove name="X-Powered-By" />
        <remove name="X-AspNet-Version" />
        <remove name="X-AspNetMvc-Version" />
        <remove name="Server" />
        <remove name="X-Forwarded-Host" />
        <remove name="X-Host" />
        <remove name="Forwarded" />
        <remove name="X-Forwarded-Server" />

        <!-- CORS Configuration -->
        <add name="Access-Control-Allow-Origin" value="https://hsac.org.in" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, OPTIONS" />
        <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization, X-Requested-With" />
        <add name="Access-Control-Allow-Credentials" value="true" />
        <remove name="Vary" />
        <add name="Vary" value="Origin" />

        <!-- Security Headers -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />

        <!-- Correct Referrer Policy -->
        <remove name="Referrer-Policy" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />

        <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
        <add name="Cross-Origin-Embedder-Policy" value="same-origin" />
        <add name="Cross-Origin-Resource-Policy" value="same-origin" />
        <add name="Cross-Origin-Opener-Policy" value="same-origin" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Content-Security-Policy" value="frame-ancestors 'self';" />
      </customHeaders>
    </httpProtocol>

    <!-- Hide server details in errors (remote) -->
    <httpErrors errorMode="DetailedLocalOnly" />

    <!-- For some legacy configs / modules -->
    <validation validateIntegratedModeConfiguration="false" />
  </system.webServer>

</configuration>