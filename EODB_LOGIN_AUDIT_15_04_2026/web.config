<configuration>
<system.web>
    <!-- Secure Cookies -->
    <httpCookies httpOnlyCookies="true" requireSSL="true" sameSite="Strict" />



    <!-- Session Security -->
    <sessionState mode="InProc" timeout="30" cookieSameSite="Strict" regenerateExpiredSessionId="true" />

    <!-- Remove ASP.NET version leak -->
    <httpRuntime enableVersionHeader="false" />
      <customErrors mode="off" />
       <pages enableViewStateMac="true" enableEventValidation="true" />
  </system.web>
  <location path="">
  <system.webServer>
    <!-- indicates that the hello.js file is a node.js application 
    to be handled by the iisnode module -->
    <handlers>
      <add name="iisnode" path="app.js" verb="*" modules="iisnode" />
    </handlers>
     <iisnode enableXFF="true" debuggingEnabled="true" />
    <!-- use URL rewriting to redirect the entire branch of the URL namespace
    to hello.js node.js application; for example, the following URLs will 
    all be handled by hello.js:

  
  
        http://localhost/node/express/myapp/foo
        http://localhost/node/express/myapp/  
              
    -->  
    <staticContent>
        <clientCache cacheControlMode="DisableCache" />
             
      </staticContent>
       <!-- Request Filtering -->
       <security>
        <requestFiltering removeServerHeader="true">
          <verbs allowUnlisted="true">
            <!-- Block Dangerous Methods -->
            <remove verb="TRACE" />
            <remove verb="TRACK" />
            <remove verb="PUT" />
            <remove verb="DELETE" />
            <remove verb="CONNECT" />
            <remove verb="OPTIONS" />

            <!-- Explicitly Deny Dangerous Verbs -->
            <add verb="TRACE" allowed="false" />
            <add verb="TRACK" allowed="false" />
            <add verb="PUT" allowed="false" />
            <add verb="DELETE" allowed="false" />
            <add verb="CONNECT" allowed="false" />
            <add verb="OPTIONS" allowed="false" />
            <add verb="HEAD" allowed="false" />

            <!-- Allow Safe Methods -->
            <add verb="GET" allowed="true" />
            <add verb="POST" allowed="true" />
          </verbs>

          <!-- Hide Sensitive Paths -->
          <hiddenSegments>
            <add segment="node" />
            <add segment="configuration" />
            <add segment="iisnode" />
            <add segment="package.json" />
            <add segment="Public" />
            <add segment="package-lock.json" />
            
          </hiddenSegments>
           
        </requestFiltering>
      </security>

    <rewrite>
    <rewriteMaps>
          <rewriteMap name="AllowedOrigins">
            <add key="https://hsac.org.in" value="https://hsac.org.in" />
          </rewriteMap>
        </rewriteMaps>

        <rules>
          <!-- Redirect All HTTP to HTTPS -->

        <rule name="Redirect to HTTPS" stopProcessing="true">
          <match url="(https://hsac.org.in)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>
       
  
          <rule name="Force HTTPS" stopProcessing="true">
            <match url="(.*)" />
            <conditions>
              <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            </conditions>
            <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
          </rule>

          <rule name="EnforceAllowedHost" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- Allow only hsac.org.in -->
            <add input="{HTTP_HOST}" pattern="^(?:hsac\.org\.in|www\.hsac\.org\.in)$" negate="true" />
          </conditions>
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Invalid Host header" />
        </rule>

     

        

          <!-- Route Dynamic Requests -->
          <rule name="NodeRule" stopProcessing="true">
            <match url="/*" />
            <action type="Rewrite" url="app.js" />
          </rule>
        </rules>

        <!-- Outbound Rules for Secure Cookies & HSTS -->
        <outboundRules>
          <remove name="Remove Server Header" />
        <!-- <rule name="Add Cookie Security Flags">
          <match serverVariable="RESPONSE_Set-Cookie" pattern="https://hsac.org.in" />
          <action type="Rewrite" value="{R:0}; Domain=hsac.org.in; Path=/; HttpOnly=True; Secure=True; SameSite=Strict" />
        </rule> -->

        <rule name="Add Cookie Security Flags" enabled="true">
          <match serverVariable="RESPONSE_Set-Cookie" pattern=".*" />
          <conditions>
          <add input="{RESPONSE_Set-Cookie}" pattern="HttpOnly" negate="true" />
          </conditions>
          <action type="Rewrite"
          value="{R:0}; HttpOnly=True; Secure=True; SameSite=Strict" />
        </rule>

          <rule name="Add HSTS Header">
            <match serverVariable="RESPONSE_Strict-Transport-Security" pattern=".*" />
            <conditions>
              <add input="{HTTPS}" pattern="on" ignoreCase="true" />
            </conditions>
            <action type="Rewrite" value="max-age=31536000; includeSubDomains; preload" />
          </rule>

          <rule name="Remove Server Header" preCondition="IsServerHeader">
          <match serverVariable="RESPONSE_Server" pattern=".+" />
          <action type="Rewrite" value="Secure" />
        </rule>

          <!-- ✅ NEW RULE to Remove Invalid Header -->
          <rule name="RemoveInvalidReferrerPolicy" preCondition="HasInvalidReferrer">
            <match serverVariable="RESPONSE_strict-origin-when-cross-origin" pattern=".*" />
            <action type="Rewrite" value="" />
          </rule>

          <preConditions>
            <preCondition name="HasInvalidReferrer">
              <add input="{RESPONSE_strict-origin-when-cross-origin}" pattern=".*" />
              
            </preCondition>

            <preCondition name="IsServerHeader">
            <add input="{RESPONSE_Server}" pattern=".+" />
          </preCondition>
          </preConditions>
        </outboundRules>
    </rewrite>
        <defaultDocument>
            <files>
                    <clear />
                    <add value="maintain.html" />
                    <add value="Default.htm" />
                    <add value="Default.asp" />
                    <add value="index.htm" />
                    <add value="index.html" />
                    <add value="iisstart.htm" />
            </files>
        </defaultDocument> 
        <httpProtocol>
        <customHeaders>
          <!-- Remove Identifying Headers -->
          <remove name="X-Powered-By" />
          <remove name="X-AspNet-Version" />
          <remove name="Server" />
           

          <!-- CORS Configuration -->
          <add name="Access-Control-Allow-Origin" value="https://hsac.org.in" /> 
          <add name="Access-Control-Allow-Methods" value="GET, POST, OPTIONS" />
          <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization, X-Requested-With" />
          <add name="Access-Control-Allow-Credentials" value="true" />
          <remove name="Vary" />
          <add name="Vary" value="Origin" />

          <!-- Security Headers -->
          <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" />
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-Frame-Options" value="DENY" />

          <!-- ✅ Correct Referrer Policy -->
          <remove name="Referrer-Policy" />
          <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />

          <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
          <add name="Cross-Origin-Embedder-Policy" value="same-origin" />
          <add name="Cross-Origin-Resource-Policy" value="same-origin" />
          <add name="Cross-Origin-Opener-Policy" value="same-origin" />
          <add name="X-XSS-Protection" value="1; mode=block" />
          <add name="Content-Security-Policy" value="frame-ancestors 'self';" />
        </customHeaders>
      </httpProtocol>
      
       
    <modules runAllManagedModulesForAllRequests="true">
      <remove name="X-AspNetMvc-Version" />
    </modules>
      <!-- Hide Server Details in Errors -->
      <httpErrors errorMode="DetailedLocalOnly" />
      <validation validateIntegratedModeConfiguration="false" />
  </system.webServer>
  </location>           
</configuration>

                
                